{
  "name": "rd-checker-updater-desktop",
  "version": "1.1.0",
  "description": "Desktop updater client for RD Checker",
  "main": "main.js",
  "private": true,
  "author": "ProjectKung",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win nsis",
    "build:portable": "electron-builder --win portable",
    "publish:win": "electron-builder --win nsis --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.projectkung.rdchecker.updater",
    "productName": "RD Checker Updater",
    "directories": {
      "output": "dist-exe"
    },
    "files": [
      "main.js",
      "preload.js",
      "../updater-client/**/*",
      "../updater/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "ProjectKung",
        "repo": "rd-checker",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "RD-Checker-Updater-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "perMachine": false
    }
  }
}
